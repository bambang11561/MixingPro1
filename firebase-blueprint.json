{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "A safety report or finding",
      "type": "object",
      "properties": {
        "reporterName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string" },
        "recommendedAction": { "type": "string" },
        "status": { "type": "string" },
        "aiAnalysis": { "type": "object" }
      },
      "required": ["reporterName", "timestamp", "location", "type", "category", "description", "severity", "status"]
    },
    "Patrol": {
      "title": "Patrol",
      "description": "A 4K+S patrol log",
      "type": "object",
      "properties": {
        "area": { "type": "string" },
        "technician": { "type": "string" },
        "date": { "type": "string" },
        "ngCount": { "type": "number" },
        "itemsStatus": { "type": "object" },
        "itemsRemarks": { "type": "object" },
        "itemsWorkingStatus": { "type": "object" }
      },
      "required": ["area", "technician", "date"]
    },
    "ScrapData": {
      "title": "ScrapData",
      "description": "Monthly scrap data by category",
      "type": "object",
      "properties": {
        "categories": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Collection of safety reports"
    },
    "/patrols/{patrolId}": {
      "schema": { "$ref": "#/entities/Patrol" },
      "description": "Collection of patrol logs"
    },
    "/scrap/{monthId}": {
      "schema": { "$ref": "#/entities/ScrapData" },
      "description": "Scrap data stored per month (e.g. 2026-07)"
    }
  }
}
